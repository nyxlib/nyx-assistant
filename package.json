    "repository": {
        "type": "git",
        "url": "https://gitlab.in2p3.fr/lpsc-kid/nyx-assistant"
    },
    "type": "module",
    "private": true,
    "scripts": {
        "app-dev": "vite --port 2468 dev",
        "app-prod": "vite build",
        "lint": "eslint",
        "tauri-dev": "tauri dev --verbose",
        "tauri-prod": "tauri build --verbose",
        "tauri-android-deploy": "adb install ./src-tauri/gen/android/app/build/outputs/apk/universal/release/app-universal-release.apk",
        "snap-prod": "snapcraft pack && snap install *.snap --devmode --dangerous"
    },
    "dependencies": {
        "@tauri-apps/api": "^2.9.0",
        "@tauri-apps/plugin-dialog": "^2.4.2",
        "@tauri-apps/plugin-fs": "^2.4.4",
        "@tauri-apps/plugin-http": "^2.5.4",
        "@tauri-apps/plugin-notification": "^2.3.3",
        "@tauri-apps/plugin-os": "^2.3.2",
        "@tauri-apps/plugin-shell": "^2.3.3",
        "@types/uuid": "^11.0.0",
        "@vueform/multiselect": "^2.6.11",
        "bootstrap": "^5.3.8",
        "bootstrap-icons": "^1.13.1",
        "md-editor-v3": "^6.2.0",
        "uuid": "^13.0.0",
        "vue": "^3.5.25",
        "vuedraggable": "^4.1.0"
    },
    "devDependencies": {
        "@tauri-apps/cli": "^2.9.4",
        "@types/bootstrap": "^5.2.10",
        "@vitejs/plugin-vue": "^6.0.2",
        "eslint": "^9.39.1",
        "eslint-plugin-vue": "^9.33.0",
